PORT=5000
JWT_SECRET=change-this-to-a-long-random-secret
CLIENT_URL=http://localhost:3000
ADMIN_INVITE_KEY=lms-admin-invite-2026

# MySQL — users, contact messages, and course catalog persistence
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=lms-portal-db

# On first startup, existing server/data/users.json accounts are migrated into MySQL.
# Demo accounts (password: password123456):
#   Student -> alex@campus.edu | Faculty -> pshah@campus.edu | Admin -> jlee@campus.edu

# Password reset email (optional — without SMTP, reset links are logged to the server console)
PASSWORD_RESET_TTL_MINUTES=60
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=LMS Portal <noreply@campus.edu>
